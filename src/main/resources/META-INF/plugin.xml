<idea-plugin>
    <id>io.github.ibrahimio.psi-agent</id>
    <name>PSI Agent</name>
    <vendor>Ibrahim</vendor>
    <description>PSI-based code refactoring agent with AI integration</description>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- MCP server lifecycle -->
        <postStartupActivity implementation="io.github.ibrahimio.psiagent.mcp.McpServerStartupActivity"/>
        <toolWindow id="PSI Change Preview"
                    anchor="right"
                    factoryClass="io.github.ibrahimio.psiagent.toolwindow.PsiChangeToolWindowFactory"
                    canCloseContents="false"/>
    </extensions>

    <actions>
        <action id="PSIAgent.RenameMethod"
                class="io.github.ibrahimio.psiagent.actions.RenameMethodAction"
                text="Rename Symbol (PSI Agent)"
                description="Rename a class, method, field, property, or variable using PSI-based refactoring">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
